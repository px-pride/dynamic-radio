<icecast>
    <location>127.0.0.1</location>
    <admin>admin@localhost</admin>

    <limits>
        <clients>16</clients>
        <sources>4</sources>
        <queue-size>524288</queue-size>
        <client-timeout>30</client-timeout>
        <header-timeout>15</header-timeout>
        <source-timeout>10</source-timeout>
        <burst-size>262144</burst-size>
    </limits>

    <authentication>
        <!-- Source password: used by ffmpeg to push audio (match ICECAST_SOURCE_PASSWORD env var) -->
        <source-password>CHANGEME</source-password>
        <admin-user>admin</admin-user>
        <!-- Admin password: used for ICY metadata updates (match ICECAST_ADMIN_PASSWORD env var) -->
        <admin-password>CHANGEME</admin-password>
    </authentication>

    <hostname>localhost</hostname>

    <listen-socket>
        <port>8000</port>
        <bind-address>0.0.0.0</bind-address>
    </listen-socket>

    <mount type="normal">
        <mount-name>/dynamicradio</mount-name>
        <charset>UTF-8</charset>
        <public>0</public>
    </mount>

    <mount type="normal">
        <mount-name>/dynamicradio.mp3</mount-name>
        <charset>UTF-8</charset>
        <public>0</public>
    </mount>

    <fileserve>1</fileserve>

    <paths>
        <basedir>/usr/share/icecast</basedir>
        <logdir>/tmp/icecast</logdir>
        <webroot>/usr/share/icecast/web</webroot>
        <adminroot>/usr/share/icecast/admin</adminroot>
    </paths>

    <logging>
        <accesslog>access.log</accesslog>
        <errorlog>error.log</errorlog>
        <loglevel>3</loglevel>
    </logging>

    <security>
        <chroot>0</chroot>
    </security>
</icecast>
